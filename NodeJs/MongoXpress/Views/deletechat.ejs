<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete Chat</title>
</head>
<body>
    <h1>Delete Chat</h1>
    <p>Are you sure you want to delete this chat?</p>
    <p>From: <strong><%= chat.from %></strong></p>
    <p>To: <i><%= chat.to %></i></p>
    <form action="/chats/<%= chat._id %>?_method=DELETE" method="post">
        <label for="from">Enter name("from") of person deleting:</label>
        <input type="text" id="from" name="from" required><br><br>
        <button type="submit">Delete</button>
    </form>
</body>
</html>